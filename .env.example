# App Config
APP_NAME="Smart LMS"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8085
TIMEZONE=Asia/Jakarta

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_lms
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRY=86400

# Rate Limiting
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_AUTH=5

# File Upload
UPLOAD_MAX_SIZE=52428800
UPLOAD_PATH=./public/uploads

# WhatsApp Gateway
WA_PROVIDER=fonnte
WA_FONNTE_TOKEN=
WA_WABLAS_TOKEN=
WA_WABLAS_DOMAIN=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Drive OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# AI Features (optional)
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Attendance GPS
GPS_REQUIRED=false
GPS_MAX_ACCURACY=100
GPS_MAX_AGE=60
ATTENDANCE_RADIUS=150
